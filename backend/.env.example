# CortaLoom Backend Configuration
# Copy this to .env and fill in your values

# ──── Database ────
TF_DATABASE_URL=postgresql+asyncpg://triforce:triforce@localhost:5432/triforce

# ──── MinIO / S3 / Cloudflare R2 ────
TF_MINIO_ENDPOINT=localhost:9000
TF_MINIO_ACCESS_KEY=minioadmin
TF_MINIO_SECRET_KEY=minioadmin
TF_MINIO_BUCKET=triforce-uploads
TF_MINIO_USE_SSL=false

# ──── LLM API Key (Anthropic only) ────
TF_ANTHROPIC_API_KEY=sk-ant-...

# ──── API Authentication ────
# Legacy single-tenant key (used as fallback)
TF_API_KEY=change-me-to-a-secure-key

# ──── Stripe Billing ────
TF_STRIPE_SECRET_KEY=sk_test_...
TF_STRIPE_WEBHOOK_SECRET=whsec_...
TF_STRIPE_PRICE_ID_STARTER=price_...
TF_STRIPE_PRICE_ID_PROFESSIONAL=price_...
TF_STRIPE_PRICE_ID_ENTERPRISE=price_...
TF_STRIPE_OVERAGE_PRICE_ID=price_...
TF_STRIPE_METER_ID=cortaloom_extraction

# ──── Sentry Error Tracking ────
TF_SENTRY_DSN=

# ──── Environment ────
# development | staging | production
TF_ENVIRONMENT=development

# ──── Data Retention ────
# Auto-purge completed jobs older than this (days)
TF_DATA_RETENTION_DAYS=90
# Audit log retention for HIPAA compliance (~7 years)
TF_AUDIT_LOG_RETENTION_DAYS=2555

# ──── Application ────
TF_LOG_LEVEL=INFO
TF_ALLOWED_ORIGINS=["http://localhost:3000"]
TF_MAX_UPLOAD_SIZE_MB=500
